@model IEnumerable<GardenZone>;
@{
    ViewData["Title"] = "All Zones";
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th scope="col">#</th>
                <th scope="col">Name</th>
                <th scope="col">AmbientType</th>
                <th scope="col">Operations</th>
            </tr>
        </thead>
        <tbody>
            <tr class="table-success">
                <th scope="row">1</th>
                <td>Alice</td>
                <td>Active</td>
            </tr>
            <tr>
                <th scope="row">2</th>
                <td>Bob</td>
                <td>Pending</td>
            </tr>
            @foreach(var gardenZone in Model)
            {
                <tr class="table-success">
                    <th scope="row">@gardenZone.Id</th>
                    <td>@gardenZone.Name</td>
                    <td>@gardenZone.GardenAmbientType</td>
                </tr>
            }
        </tbody>
    </table>
</div>
